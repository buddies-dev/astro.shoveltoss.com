---
interface Props {
	title: string;
	heading: string;
}

import { Image } from 'astro:assets';
import shovels from '@public/cross-shovels2.png';

import Nav from "@components/Nav.astro"
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

const { heading, title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Shoveltoss — the shovel-based pastime. Rules, champions, gallery, and merch." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🍺</text></svg>">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<ClientRouter />
		<script is:inline async src="https://us.umami.is/script.js" data-website-id="24cddf39-bdf1-46c4-97bd-64faa0f48d77"></script>
	</head>
	<body class="flex min-h-dvh flex-col bg-[--color-bg] text-[--color-fg]">
		<header class="flex flex-col items-center gap-2 px-4 py-3 sm:gap-4 sm:py-6">
			<h1 class="text-center text-2xl font-bold leading-tight sm:text-4xl">{heading}</h1>
			<Nav />
		</header>
		<main class="mx-auto w-full max-w-3xl flex-1 px-4 py-6 sm:px-6 sm:py-10">
			<slot />
		</main>
		<footer class="flex flex-col items-center justify-center gap-1 p-2">
			<Image alt="shovel lol" class="h-16 w-auto sm:h-20" src={shovels} loading="lazy" />
			<p class="text-xs">Shoveltoss &copy; 2023 - Buddies Inc.</p>
		</footer>
	</body>
</html>
