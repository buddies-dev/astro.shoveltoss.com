---
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import images from '@public/images.json';

const gallery = images.gallery;
---

<Layout heading="Gallery 🖼️" title="Welcome to Astro.">
	<div class="flex flex-col flex-wrap content-center md:grid lg:grid xl:grid lg:grid-cols-3 gap-4">
		{
			gallery.map((image) => {
				return (
					<div class="relative lg:overflow-hidden lg:max-h-[185px]">
						<a target="_blank" href={image} title="Click to view in new tab.">
							<Image
								alt="Gallery image"
								height="500"
								width="500"
								class="h-full w-full lg:object-cover lg:object-center rounded-md"
								src={image}
								loading="lazy"
							/>
						</a>
					</div>
				)
			})
		}
	</div>
</Layout>
