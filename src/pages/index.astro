---
import Layout from '@layouts/Layout.astro';
import { cld, srcset } from '../lib/cloudinary';
import { gameUrl } from '../lib/nav';

const currentYear = new Date().getFullYear();
const heroGif1 = 'https://res.cloudinary.com/shoveltoss-com/image/upload/v1630897183/shoveltoss.com/new-gif_soend3.gif';
const heroGif2 = 'https://res.cloudinary.com/shoveltoss-com/image/upload/v1630897147/shoveltoss.com/new-gif_z5tflr.gif';
const buddies = 'https://res.cloudinary.com/shoveltoss-com/image/upload/v1630898108/shoveltoss.com/05a78d71b6c1491199825af89d3a1154_qflxtq.jpg';
const heroSizes = '(min-width: 768px) 12rem, 50vw';
const heroVideoAttrs = {
	autoplay: true,
	loop: true,
	muted: true,
	playsinline: true,
	preload: 'metadata',
};
---

<Layout
	heading="Shoveltoss 🍺"
	title="Welcome to Shoveltoss."
	lcpImage={{
		src: cld(heroGif1, { w: 240, c: 'fill', ar: '1:1', format: 'jpg' }),
		srcset: srcset(heroGif1, [240, 480], { c: 'fill', ar: '1:1', format: 'jpg' }),
		sizes: heroSizes,
	}}
>
	<div class="space-y-6">
		<div class="space-y-3 text-center">
			<p class="text-lg">Welcome to the official Shoveltoss website.</p>
		</div>

		<div class="mx-auto flex w-full max-w-sm justify-center">
			<video
				class="aspect-square w-1/2 rounded-l-md object-cover"
				poster={cld(heroGif1, { w: 240, c: 'fill', ar: '1:1', format: 'jpg' })}
				width="240"
				height="240"
				{...heroVideoAttrs}
			>
				<source src={cld(heroGif1, { w: 240, c: 'fill', ar: '1:1', format: 'mp4' })} type="video/mp4" />
			</video>
			<video
				class="aspect-square w-1/2 rounded-r-md object-cover"
				poster={cld(heroGif2, { w: 240, c: 'fill', ar: '1:1', format: 'jpg' })}
				width="240"
				height="240"
				{...heroVideoAttrs}
			>
				<source src={cld(heroGif2, { w: 240, c: 'fill', ar: '1:1', format: 'mp4' })} type="video/mp4" />
			</video>
		</div>

		<a
			href={gameUrl}
			target="_blank"
			rel="noopener noreferrer"
			class="shine-card group mx-auto flex w-full max-w-md items-center justify-between gap-4 rounded-lg bg-[--color-surface] px-5 py-4 transition"
		>
			<div class="flex flex-col">
				<span class="text-lg font-semibold">Play Shoveltoss</span>
				<span class="text-sm text-zinc-400">Try the browser game at shoveltoss.ing</span>
			</div>
			<span class="text-2xl transition group-hover:translate-x-0.5">🪏</span>
		</a>

		<div class="grid gap-6 sm:grid-cols-2 sm:items-center">
			<div class="space-y-3">
				<p class="text-base text-[--color-fg-muted]">Shoveltoss is a phenomena manifested in the heart of Little Italy by two boys and the dream of a better shovel-based pastime.</p>
				<p class="text-base text-[--color-fg-muted]">With it's inaugural tournament in the summer of 2016, Shoveltoss is going strong in it's {currentYear - 2016}th year and third venue!</p>
			</div>
			<img
				class="rounded-md"
				alt="buddies"
				src={cld(buddies, { w: 600 })}
				srcset={srcset(buddies, [400, 600, 800])}
				sizes="(min-width: 640px) 50vw, 100vw"
				width="600"
				height="450"
				loading="lazy"
				decoding="async"
			/>
		</div>
	</div>
</Layout>
