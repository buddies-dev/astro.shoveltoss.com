---
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import chuggo from '@public/chuggo.png';
import shrek from '@public/shrek.png';
import lucha from '@public/lucha.png';

const currentYear = new Date().getFullYear();
---

<Layout heading="Shoveltoss 🍺" title="Welcome to Shoveltoss.">
	<div class="space-y-6">
		<div class="space-y-3 text-center">
			<p class="text-lg">Welcome to the official Shoveltoss website.</p>
			<div class="hidden justify-center gap-4 sm:flex">
				<Image alt="" class="h-16 w-auto" src={chuggo} />
				<Image alt="" class="h-16 w-auto" src={shrek} />
				<Image alt="" class="h-16 w-auto" src={lucha} />
			</div>
		</div>

		<div class="mx-auto flex w-full max-w-sm justify-center">
			<img
				class="aspect-square w-1/2 rounded-l-md object-cover"
				src="https://res.cloudinary.com/shoveltoss-com/image/upload/c_fill,h_240,w_240/v1630897183/shoveltoss.com/new-gif_soend3.gif"
				alt=""
				width="240"
				height="240"
			/>
			<img
				class="aspect-square w-1/2 rounded-r-md object-cover"
				src="https://res.cloudinary.com/shoveltoss-com/image/upload/c_fill,h_240,w_240/v1630897147/shoveltoss.com/new-gif_z5tflr.gif"
				alt=""
				width="240"
				height="240"
			/>
		</div>

		<a
			href="https://shoveltoss.ing"
			target="_blank"
			rel="noopener noreferrer"
			class="group mx-auto flex w-full max-w-md items-center justify-between gap-4 rounded-lg bg-[--color-surface] px-5 py-4 ring-1 ring-white/10 transition hover:ring-[--color-accent]"
		>
			<div class="flex flex-col">
				<span class="text-lg font-semibold">Play Shoveltoss</span>
				<span class="text-sm text-[--color-fg-muted]">Try the browser game at shoveltoss.ing</span>
			</div>
			<span class="text-2xl transition group-hover:translate-x-0.5">🎮</span>
		</a>

		<div class="grid gap-6 sm:grid-cols-2 sm:items-center">
			<div class="space-y-3">
				<p class="text-base text-[--color-fg-muted]">Shoveltoss is a phenomena manifested in the heart of Little Italy by two boys and the dream of a better shovel-based pastime.</p>
				<p class="text-base text-[--color-fg-muted]">With it's inaugural tournament in the summer of 2016, Shoveltoss is going strong in it's {currentYear - 2016}th year and third venue!</p>
			</div>
			<img class="rounded-md" alt="buddies" src="https://res.cloudinary.com/shoveltoss-com/image/upload/v1630898108/shoveltoss.com/05a78d71b6c1491199825af89d3a1154_qflxtq.jpg" />
		</div>
	</div>
</Layout>
