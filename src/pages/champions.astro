---
import Layout from '@layouts/Layout.astro';
import ChampionCard from '@components/ChampionCard.astro';

const max2018 = 'https://res.cloudinary.com/shoveltoss-com/image/upload/v1630213818/shoveltoss.com/dc278719-609f-4a28-9c96-3df8cfae1ea0.jpg';
const phil2019 = 'https://res.cloudinary.com/shoveltoss-com/image/upload/v1630898121/shoveltoss.com/5738b77dcfad401e85ff70b877f35bf8_k2isey.jpg';
const nick2023 = 'https://res.cloudinary.com/shoveltoss-com/image/upload/v1699066023/shoveltoss.com/IMG_4400_bewhqj.png';
---

<Layout heading="Champions 👑" title="Welcome to Astro.">
	<div class="space-y-6">
		<ChampionCard year={2016} name="Brian A." titles={1}>
			The OG. A real pioneer. The George Washington of Shoveltoss, if you will.
		</ChampionCard>
		<ChampionCard year={2017} name="Alex E." titles={1}>
			An absolute force. A legendary performance with coaching by the mastermind Joe.
		</ChampionCard>
		<ChampionCard year={2018} name="Max V." titles={1} image={max2018}>
			Winning in the sloppiest conditions on record make his success only more impressive.
		</ChampionCard>
		<ChampionCard year={2019} name="Phil D." titles={1} image={phil2019}>
			Inaugural champion of the newest Shoveltoss venue. Second win for coach Joe.
		</ChampionCard>
		<ChampionCard year={2021} name="Nick P" titles={1}>
			First champion in the post-COVID era. Myocarditis and lung scarring are no match for a real champ.
		</ChampionCard>
		<ChampionCard year={2023} name="Nick P." titles={2} image={nick2023}>
			Our first back to back champion. Chuggo is too nasty with it.
		</ChampionCard>
	</div>
</Layout>
