---
import Layout from '@layouts/Layout.astro';
import RuleSection from '@components/RuleSection.astro';
---

<Layout heading="Rules 📒" title="Rules 📒">
  <div class="space-y-6">
    <div class="flex flex-col gap-6 sm:flex-row sm:gap-12">
      <div class="space-y-3">
        <h2 class="text-xl font-semibold underline">How to Win</h2>
        <ul class="space-y-1 text-base">
          <li>First to 15 wins.</li>
          <li>3 points are awarded for a <span class="italic">shovel stick</span>.</li>
          <li>2 points are awarded for a shovel leaning against the back wall.</li>
          <li>1 point is awarded for the shovel lying fully in the garden.</li>
          <li>0 points are awarded if the shovel is touching any part of the front wall.</li>
          <li>-2 points are awarded if the shovel lands completely outside the garden.</li>
        </ul>
      </div>
    </div>
    <div>
      <div class="space-y-4">
        <h2 class="text-xl font-semibold underline">Gameplay</h2>
        <RuleSection title="Determine the Order">
          A game of rock-paper-scissors is held. The winner chooses whether to go first or second.
        </RuleSection>
        <RuleSection title="Inning">
          Each person receives one toss per inning, in the order established at the start of the match, until one player reaches exactly 15. If the first player to toss reaches 15, the inning is still completed. Announce the score after every inning.
        </RuleSection>
        <RuleSection title="Going Over">
          If a player goes over 15 points, the number of points over 15 is subtracted from 15, and the result becomes their new score. For example, if a player reaches 17, they are 2 over 15, so 15 - 2 = 13. Their score is now 13.
        </RuleSection>
        <RuleSection title="Redemption">
          If one contestant reaches exactly 15 points at the end of an inning, the other player gets a redemption shot. If they stick the shovel in the garden, they receive another throw. They continue throwing until they reach exactly 15 points or fail to stick the shovel in the garden.
        </RuleSection>
        <RuleSection title="Overtime">
          Overtime occurs if both players reach exactly 15, either during regulation or through redemption.
        </RuleSection>
        <RuleSection title="Determine the Order">
          The first player to reach 15 chooses whether to go first or second.
        </RuleSection>
        <RuleSection title="Play">
          Players receive three alternating throws. The highest score after those three throws wins. If there is a tie, overtime goes to sudden death.
        </RuleSection>
        <RuleSection title="Sudden Death">
          Each player throws one shovel, trying to stick it in the garden. The first player to stick their shovel without the other player also completing a stick wins.
        </RuleSection>
      </div>
    </div>
  </div>
</Layout>
