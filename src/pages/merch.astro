---
import { Image } from 'astro:assets';
import Layout from '@layouts/Layout.astro';
import images from '@public/images.json';

const gallery = images.shop;
---

<Layout heading="Merch 🧢" title="Welcome to Astro.">
	{
		gallery.map((image: string) => {
			return (
				<Image
					height="500"
					width="500"
					alt="merch"
					loading="lazy"
					class="lg:max-w-[50vh] self-center rounded-md"
					src={image}
				/>
			)
		})
	}
</Layout>
