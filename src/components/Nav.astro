---
import { navLinks } from '../lib/nav';
---

<nav class="flex flex-wrap justify-center gap-x-5 gap-y-1 text-base sm:gap-x-6">
	{navLinks.map(({ href, label }) => (
		<a
			href={href}
			class:list={[
				"py-1 underline-offset-4 hover:underline",
				Astro.url.pathname === href && "underline"
			]}
		>
			{label}
		</a>
	))}
</nav>
